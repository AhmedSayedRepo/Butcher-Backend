generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  // v2 replan (Phase D — RBAC): fine-grained capability toggles per user,
  // modeled on qa-studio's role-plus-capability pattern. Schema added now
  // (Phase 0) so downstream phases don't need another migration; the actual
  // role-check middleware/UI ships in Phase D. Default "[]" (no extra caps
  // beyond whatever `role` implies) so this is a no-op for the existing
  // single admin user until Phase D assigns real values.
  caps      Json     @default("[]")
  // v3 follow-up (admin-invite auth flow): false for an account an admin
  // just invited by email — it's created with an unusable random password
  // hash (same pattern as the WhatsApp system user in seed.ts) until the
  // invitee follows their emailed link and sets a real one via
  // POST /auth/reset-password. Defaults true so every pre-existing user
  // (and the seeded admin) is unaffected. Purely a UI/status flag — actual
  // login is gated by whether the stored hash matches, not this field.
  passwordSet Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders              Order[]
  statusEvents        OrderStatusEvent[]
  stockAdjustments    StockAdjustment[]
  dismantleEvents     DismantleEvent[]
  cashTransactions    CashTransaction[]
  passwordResetTokens PasswordResetToken[]
  dailyClosings       DailyClosing[]
}

// v3 follow-up: backs both the admin-invite "set your password" flow and
// self-service "forgot password" — same mechanism either way (a
// single-use, expiring, random token mailed to the account's email
// address), so one model covers both rather than two near-duplicate ones.
// `purpose` only changes the email copy/link label, not the validation
// logic, which is identical for both cases.
enum PasswordResetTokenPurpose {
  INVITE
  RESET
}

model PasswordResetToken {
  id        String                    @id @default(uuid())
  userId    String
  token     String                    @unique
  purpose   PasswordResetTokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                  @default(now())

  user User @relation(fields: [userId], references: [id])
}

// v3 replan (Phase H — CRM). Deliberately minimal (ADR-013 / "Customer data
// is minimal and deletable" in Butcher-Project-Plan-v3.md's best-practices
// section) — no speculative marketing-CRM fields (campaigns/segments/tags).
// `Order.customer` (free text) is untouched and still covers anonymous
// walk-ins; `Order.customerId` is an optional link on top, so nothing about
// today's order flow changes for orders that never reference a Customer.
model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  // v3 follow-up: requested alongside `notes` (which already existed but had
  // no create/edit UI wired up until now — only the backend accepted it).
  // Useful for delivery-order customers even though `Order.deliveryAddress`
  // is captured per-order too (a customer's usual address vs. a one-off
  // delivery destination for a specific order are legitimately different —
  // this doesn't replace that field, it just saves re-typing the common case).
  address   String?  @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// v3 replan (Phase K — cash management). Append-only ledger (ADR-011) — a
// mistaken entry is corrected by inserting a reversing transaction, never by
// UPDATE/DELETE on the original row, same as StockAdjustment/
// OrderStatusEvent elsewhere in this schema.
enum CashTransactionType {
  IN
  OUT
}

model CashTransaction {
  id        String              @id @default(uuid())
  type      CashTransactionType
  category  String              // e.g. "sale" (auto-logged), "deposit", "supplier_payment", "petty_cash", "correction"
  amount    Decimal             @db.Decimal(10,2)
  note      String?
  userId    String
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])
}

// v3 replan (Phase J — pending-order alerting). Single-row config table:
// "how long is too long for a pending order" is shop policy, not a
// per-user preference, so this is one row, not User-scoped settings.
model ShopSettings {
  id                      String  @id @default(uuid())
  pendingOrderAlertMinutes Int    @default(30)
  alertSoundEnabled       Boolean @default(true)
  // v3.1 replan (Phase L — daily order numbering + closing day, ADR-015).
  // Running counter behind Order.dailyNumber, incremented atomically
  // (lib/dailyOrderNumber.ts) on every order/draft creation. Reset to 0 by
  // POST /api/shop-settings/close-day (the "closing day" button in Cash
  // Management) so tomorrow's first order is #1 again. `lastClosedAt` is
  // the boundary the next closing's summary is computed from.
  dailyOrderCounter       Int      @default(0)
  lastClosedAt            DateTime?
  // v3.1 follow-up 5 (Settings page). Both previously hardcoded constants
  // duplicated across backend (lib/lowStock.ts, lib/email.ts) and frontend
  // (app/page.tsx, app/inventory/page.tsx) — now single-sourced here and
  // editable from /settings (admin-only, same tier as the other fields on
  // this model). `defaultLowStockThresholdKg` is the shop-wide fallback used
  // when a product has no per-product `lowStockAlertKg` override.
  // `mailSenderName` is the display name shown on outgoing invite/reset
  // emails (lib/email.ts) — the address itself is always the authenticated
  // SMTP_USER, only the name is configurable.
  defaultLowStockThresholdKg Decimal @default(5) @db.Decimal(10, 3)
  mailSenderName             String  @default("Butcher Cashier")
  // v3.1 follow-up 9 (ADR-016). SMTP_USER/SMTP_APP_PASSWORD were previously
  // env-var-only (set on Render, no redeploy needed but a separate login
  // from the app). Now editable from /settings instead: `smtpUser` is
  // plaintext (it's just an email address, not a secret — it's visible in
  // every outgoing message's From header anyway). `smtpAppPasswordEncrypted`
  // is the Gmail app password, but NEVER stored raw — always AES-256-GCM
  // ciphertext via lib/encryption.ts, keyed by the SETTINGS_ENCRYPTION_KEY
  // env var (which itself never leaves env vars). Both are nullable and
  // fall back to the original SMTP_USER/SMTP_APP_PASSWORD env vars when
  // unset, so an existing env-var-only deployment keeps working unchanged
  // until someone actually fills in /settings.
  smtpUser                  String?
  smtpAppPasswordEncrypted  String?
}

// v3 replan — idempotency guard for order-creation and cash-transaction
// endpoints (the plan's "Idempotency — a real gap, not a solved problem"
// finding: nothing in this app previously protected against a duplicate
// submission from a double-click or a retried network request). A repeat
// request carrying the same client-generated key returns the stored
// response instead of re-executing the write.
model IdempotencyKey {
  id           String   @id @default(uuid())
  key          String
  endpoint     String
  responseBody Json
  createdAt    DateTime @default(now())

  @@unique([key, endpoint])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  unit        String   @default("kg")
  pricePerKg  Decimal  @db.Decimal(10,2)
  stockKg     Decimal  @db.Decimal(10,3)
  // v2 replan (Phase B — inventory upgrades). Both optional/nullable so
  // every existing product row stays valid with no backfill required.
  category        String?
  lowStockAlertKg Decimal? @db.Decimal(10,3)
  // v3 replan (Phase I.1 — barcode scanning). Optional/unique so existing
  // products stay valid unbackfilled; a scanner is a keyboard-emulation
  // device feeding a lookup against this field (ADR-008), not a device
  // integration.
  barcode         String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items            OrderItem[]
  stockAdjustments StockAdjustment[]
  dismantleOutputs DismantleEventOutput[]
}

// v2 replan (Phase C — order kanban). DRAFT = saved but not yet promoted
// (no stock decrement yet, see Order.status default below); CREATED is the
// same state every existing order is already in today, so the default below
// keeps every current row valid with no backfill.
// v3.1 follow-up 6 (final order state + receipt confirmation). COMPLETED is
// the one true terminal "done" state for a fulfilled order (CANCELLED is
// terminal too, but means the opposite — never happened). Reachable two
// ways, deliberately different in trust level: IN_PREMISE -> COMPLETED is a
// plain manual staff action (PATCH /:id/status) since a walk-in/pickup
// order is handed over and paid for in front of the cashier already.
// ON_THE_WAY -> COMPLETED requires scanning the order's `receiptCode` via
// POST /:id/scan-receipt instead — a delivery order's cash is only
// confirmed once the receipt physically comes back, so the status change
// shouldn't be a single unchecked button click the way every other
// transition is.
enum OrderStatus {
  DRAFT
  CREATED
  IN_PROGRESS
  ON_THE_WAY
  IN_PREMISE
  COMPLETED
  CANCELLED
}

model Order {
  id          String      @id @default(uuid())
  // v3.1 replan (Phase L — daily order numbering, ADR-015). Human-friendly
  // "#N" sequence shown in the UI/receipts/notifications, assigned
  // atomically at creation time (lib/dailyOrderNumber.ts) and reset to 0 by
  // the closing-day action — never the real key for anything (that stays
  // `id`, the uuid, everywhere: FKs, the API, idempotency lookups). Nullable
  // so every pre-migration order row stays valid with no backfill.
  dailyNumber Int?
  customer    String?
  totalAmount Decimal     @db.Decimal(10,2)
  status      OrderStatus @default(CREATED)
  // v2 replan (Phase G — WhatsApp intake): "cashier" | "whatsapp". Default
  // matches every order created before this migration.
  source      String      @default("cashier")
  // v3 replan (Phase I.2 — WhatsApp order intake): the raw inbound message
  // text, kept verbatim alongside the parsed items so staff can review what
  // the customer actually wrote (parsing is best-effort — see
  // lib/parseOrderMessage.ts — and unmatched items never become OrderItem
  // rows, so this is the only record of them). Null for every non-WhatsApp
  // order.
  customerMessage String?  @db.Text
  // v3 replan (Phase H — CRM). Optional link on top of the existing free-text
  // `customer` field — nothing about today's order flow changes for orders
  // that never reference a real Customer record. SetNull on delete so
  // deleting a Customer (ADR-013) never cascades into deleting order/
  // financial history, only de-links it from the removed person.
  customerId      String?
  customerRecord  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // v3 replan (Phase I.3 — phone delivery orders). Null for every other source.
  deliveryAddress String?  @db.Text
  // v3 replan (Phase K — cash management): which payment rail this order
  // used. Free-text default "cash" rather than a DB enum, matching how
  // `source` is already modeled — extending the set of understood values
  // later is a zero-migration zod change. Only paymentMethod === "cash"
  // orders auto-log a CashTransaction (ADR-011); other values are recorded
  // but not yet reconciled against a rail-specific ledger (out of scope
  // until non-cash payment methods are confirmed in use — see v3 plan's
  // open question 4).
  paymentMethod   String   @default("cash")
  // v3.1 follow-up 6: short random code (lib/receiptCode.ts) assigned once
  // an order becomes real (creation or draft promotion — never on a
  // DRAFT), printed on the receipt. The only way an ON_THE_WAY order can
  // reach COMPLETED — see the OrderStatus comment above. Nullable because
  // pre-migration order rows have none, and DRAFT rows never get one at
  // all (nothing to scan for an order that hasn't happened yet).
  receiptCode String? @unique
  createdAt   DateTime    @default(now())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  statusEvents OrderStatusEvent[]
}

// Append-only history of Order.status transitions — see ADR-006 in
// Butcher-Project-Plan-v2.md for why this is a separate table rather than
// just overwriting Order.status: the kanban board and dashboard charts both
// need "when did this change," which a single column can't retain.
model OrderStatusEvent {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  createdAt DateTime    @default(now())
  changedBy String?     // userId; null for system/automated transitions (e.g. a WhatsApp bot promoting an order with no logged-in user driving it)

  order         Order @relation(fields: [orderId], references: [id])
  changedByUser User? @relation(fields: [changedBy], references: [id])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  kg         Decimal  @db.Decimal(10,3)
  price      Decimal  @db.Decimal(10,2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// v2 replan (Phase B — inventory upgrades): records *why* stockKg changed
// outside of a normal order (restock, correction, shrinkage/waste), rather
// than letting PATCH /api/products/:id silently overwrite it with no trail.
model StockAdjustment {
  id        String   @id @default(uuid())
  productId String
  deltaKg   Decimal  @db.Decimal(10,3) // positive = added (restock), negative = removed (shrinkage/correction)
  reason    String
  userId    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

// v2 replan (Phase B.5 — carcass dismantling module: calf, sheep, goat).
// A template is just data (seeded, not hardcoded) describing one way to
// break an animal down into named cuts with an expected yield %.
model DismantleTemplate {
  id          String   @id @default(uuid())
  name        String                        // e.g. "Standard 5-Primal (USDA)"
  animalType  String   @default("calf")     // "calf" | "sheep" | "goat" today; a new animal is just a new row, no schema change
  description String?
  createdAt   DateTime @default(now())

  cuts   DismantleTemplateCut[]
  events DismantleEvent[]
}

model DismantleTemplateCut {
  id               String   @id @default(uuid())
  templateId       String
  cutName          String                   // e.g. "Shoulder", "Rib (Hotel Rack)", "Offal"
  expectedYieldPct Decimal  @db.Decimal(5,2) // % of carcass weight, for variance reporting
  isOffal          Boolean  @default(false)  // flags organ-meat/"fifth quarter" lines so the UI can subtotal them separately from primal cuts
  // v3.1 follow-up 7: flags non-edible slaughter byproducts (hide/pelt,
  // blood, head/feet) on "Whole Animal (On-Site Slaughter)" templates —
  // distinct from isOffal (edible organ meat). Lets the UI tag/subtotal
  // these separately instead of them either being missing entirely or
  // getting lumped in with real meat cuts.
  isByproduct      Boolean  @default(false)

  template DismantleTemplate @relation(fields: [templateId], references: [id])
}

// One real event: a specific carcass, weighed in, broken down per a template.
model DismantleEvent {
  id            String   @id @default(uuid())
  templateId    String
  sourceLabel   String                       // e.g. "Calf #48, supplier X"
  inputWeightKg Decimal  @db.Decimal(10,3)   // whole/half carcass weight as received
  performedBy   String                       // userId
  createdAt     DateTime @default(now())

  template DismantleTemplate     @relation(fields: [templateId], references: [id])
  user     User                  @relation(fields: [performedBy], references: [id])
  outputs  DismantleEventOutput[]
}

// v3.1 replan (Phase L — closing day, ADR-015). One row per "closing day"
// action — an audit trail / point-in-time snapshot, consistent with this
// app's append-only-ledger pattern elsewhere (StockAdjustment/
// OrderStatusEvent/CashTransaction are never edited or deleted, only
// appended to). Doesn't replace CashTransaction's own history; this is a
// rollup taken at the moment ShopSettings.dailyOrderCounter resets to 0, so
// past days/shifts stay reviewable after the counter moves on.
model DailyClosing {
  id           String   @id @default(uuid())
  closedAt     DateTime @default(now())
  closedBy     String
  orderCount   Int
  totalRevenue Decimal  @db.Decimal(10,2)
  cashIn       Decimal  @db.Decimal(10,2)
  cashOut      Decimal  @db.Decimal(10,2)
  netPosition  Decimal  @db.Decimal(10,2)

  closedByUser User @relation(fields: [closedBy], references: [id])
}

model DismantleEventOutput {
  id             String   @id @default(uuid())
  eventId        String
  cutName        String
  actualWeightKg Decimal  @db.Decimal(10,3)  // what the scale actually said
  isOffal        Boolean  @default(false)    // copied from the template cut at record time, in case the template changes later
  isByproduct    Boolean  @default(false)    // same "copied at record time" reasoning as isOffal — see DismantleTemplateCut
  productId      String?                    // which inventory Product this got stocked into, if any

  event   DismantleEvent @relation(fields: [eventId], references: [id])
  product Product?       @relation(fields: [productId], references: [id])
}
