generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  // v2 replan (Phase D — RBAC): fine-grained capability toggles per user,
  // modeled on qa-studio's role-plus-capability pattern. Schema added now
  // (Phase 0) so downstream phases don't need another migration; the actual
  // role-check middleware/UI ships in Phase D. Default "[]" (no extra caps
  // beyond whatever `role` implies) so this is a no-op for the existing
  // single admin user until Phase D assigns real values.
  caps      Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders            Order[]
  statusEvents      OrderStatusEvent[]
  stockAdjustments  StockAdjustment[]
  dismantleEvents   DismantleEvent[]
  cashTransactions  CashTransaction[]
}

// v3 replan (Phase H — CRM). Deliberately minimal (ADR-013 / "Customer data
// is minimal and deletable" in Butcher-Project-Plan-v3.md's best-practices
// section) — no speculative marketing-CRM fields (campaigns/segments/tags).
// `Order.customer` (free text) is untouched and still covers anonymous
// walk-ins; `Order.customerId` is an optional link on top, so nothing about
// today's order flow changes for orders that never reference a Customer.
model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// v3 replan (Phase K — cash management). Append-only ledger (ADR-011) — a
// mistaken entry is corrected by inserting a reversing transaction, never by
// UPDATE/DELETE on the original row, same as StockAdjustment/
// OrderStatusEvent elsewhere in this schema.
enum CashTransactionType {
  IN
  OUT
}

model CashTransaction {
  id        String              @id @default(uuid())
  type      CashTransactionType
  category  String              // e.g. "sale" (auto-logged), "deposit", "supplier_payment", "petty_cash", "correction"
  amount    Decimal             @db.Decimal(10,2)
  note      String?
  userId    String
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])
}

// v3 replan (Phase J — pending-order alerting). Single-row config table:
// "how long is too long for a pending order" is shop policy, not a
// per-user preference, so this is one row, not User-scoped settings.
model ShopSettings {
  id                      String  @id @default(uuid())
  pendingOrderAlertMinutes Int    @default(30)
  alertSoundEnabled       Boolean @default(true)
}

// v3 replan — idempotency guard for order-creation and cash-transaction
// endpoints (the plan's "Idempotency — a real gap, not a solved problem"
// finding: nothing in this app previously protected against a duplicate
// submission from a double-click or a retried network request). A repeat
// request carrying the same client-generated key returns the stored
// response instead of re-executing the write.
model IdempotencyKey {
  id           String   @id @default(uuid())
  key          String
  endpoint     String
  responseBody Json
  createdAt    DateTime @default(now())

  @@unique([key, endpoint])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  unit        String   @default("kg")
  pricePerKg  Decimal  @db.Decimal(10,2)
  stockKg     Decimal  @db.Decimal(10,3)
  // v2 replan (Phase B — inventory upgrades). Both optional/nullable so
  // every existing product row stays valid with no backfill required.
  category        String?
  lowStockAlertKg Decimal? @db.Decimal(10,3)
  // v3 replan (Phase I.1 — barcode scanning). Optional/unique so existing
  // products stay valid unbackfilled; a scanner is a keyboard-emulation
  // device feeding a lookup against this field (ADR-008), not a device
  // integration.
  barcode         String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items            OrderItem[]
  stockAdjustments StockAdjustment[]
  dismantleOutputs DismantleEventOutput[]
}

// v2 replan (Phase C — order kanban). DRAFT = saved but not yet promoted
// (no stock decrement yet, see Order.status default below); CREATED is the
// same state every existing order is already in today, so the default below
// keeps every current row valid with no backfill.
enum OrderStatus {
  DRAFT
  CREATED
  IN_PROGRESS
  ON_THE_WAY
  IN_PREMISE
  CANCELLED
}

model Order {
  id          String      @id @default(uuid())
  customer    String?
  totalAmount Decimal     @db.Decimal(10,2)
  status      OrderStatus @default(CREATED)
  // v2 replan (Phase G — WhatsApp intake): "cashier" | "whatsapp". Default
  // matches every order created before this migration.
  source      String      @default("cashier")
  // v3 replan (Phase I.2 — WhatsApp order intake): the raw inbound message
  // text, kept verbatim alongside the parsed items so staff can review what
  // the customer actually wrote (parsing is best-effort — see
  // lib/parseOrderMessage.ts — and unmatched items never become OrderItem
  // rows, so this is the only record of them). Null for every non-WhatsApp
  // order.
  customerMessage String?  @db.Text
  // v3 replan (Phase H — CRM). Optional link on top of the existing free-text
  // `customer` field — nothing about today's order flow changes for orders
  // that never reference a real Customer record. SetNull on delete so
  // deleting a Customer (ADR-013) never cascades into deleting order/
  // financial history, only de-links it from the removed person.
  customerId      String?
  customerRecord  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // v3 replan (Phase I.3 — phone delivery orders). Null for every other source.
  deliveryAddress String?  @db.Text
  // v3 replan (Phase K — cash management): which payment rail this order
  // used. Free-text default "cash" rather than a DB enum, matching how
  // `source` is already modeled — extending the set of understood values
  // later is a zero-migration zod change. Only paymentMethod === "cash"
  // orders auto-log a CashTransaction (ADR-011); other values are recorded
  // but not yet reconciled against a rail-specific ledger (out of scope
  // until non-cash payment methods are confirmed in use — see v3 plan's
  // open question 4).
  paymentMethod   String   @default("cash")
  createdAt   DateTime    @default(now())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  statusEvents OrderStatusEvent[]
}

// Append-only history of Order.status transitions — see ADR-006 in
// Butcher-Project-Plan-v2.md for why this is a separate table rather than
// just overwriting Order.status: the kanban board and dashboard charts both
// need "when did this change," which a single column can't retain.
model OrderStatusEvent {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  createdAt DateTime    @default(now())
  changedBy String?     // userId; null for system/automated transitions (e.g. a WhatsApp bot promoting an order with no logged-in user driving it)

  order         Order @relation(fields: [orderId], references: [id])
  changedByUser User? @relation(fields: [changedBy], references: [id])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  kg         Decimal  @db.Decimal(10,3)
  price      Decimal  @db.Decimal(10,2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// v2 replan (Phase B — inventory upgrades): records *why* stockKg changed
// outside of a normal order (restock, correction, shrinkage/waste), rather
// than letting PATCH /api/products/:id silently overwrite it with no trail.
model StockAdjustment {
  id        String   @id @default(uuid())
  productId String
  deltaKg   Decimal  @db.Decimal(10,3) // positive = added (restock), negative = removed (shrinkage/correction)
  reason    String
  userId    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

// v2 replan (Phase B.5 — carcass dismantling module: calf, sheep, goat).
// A template is just data (seeded, not hardcoded) describing one way to
// break an animal down into named cuts with an expected yield %.
model DismantleTemplate {
  id          String   @id @default(uuid())
  name        String                        // e.g. "Standard 5-Primal (USDA)"
  animalType  String   @default("calf")     // "calf" | "sheep" | "goat" today; a new animal is just a new row, no schema change
  description String?
  createdAt   DateTime @default(now())

  cuts   DismantleTemplateCut[]
  events DismantleEvent[]
}

model DismantleTemplateCut {
  id               String   @id @default(uuid())
  templateId       String
  cutName          String                   // e.g. "Shoulder", "Rib (Hotel Rack)", "Offal"
  expectedYieldPct Decimal  @db.Decimal(5,2) // % of carcass weight, for variance reporting
  isOffal          Boolean  @default(false)  // flags organ-meat/"fifth quarter" lines so the UI can subtotal them separately from primal cuts

  template DismantleTemplate @relation(fields: [templateId], references: [id])
}

// One real event: a specific carcass, weighed in, broken down per a template.
model DismantleEvent {
  id            String   @id @default(uuid())
  templateId    String
  sourceLabel   String                       // e.g. "Calf #48, supplier X"
  inputWeightKg Decimal  @db.Decimal(10,3)   // whole/half carcass weight as received
  performedBy   String                       // userId
  createdAt     DateTime @default(now())

  template DismantleTemplate     @relation(fields: [templateId], references: [id])
  user     User                  @relation(fields: [performedBy], references: [id])
  outputs  DismantleEventOutput[]
}

model DismantleEventOutput {
  id             String   @id @default(uuid())
  eventId        String
  cutName        String
  actualWeightKg Decimal  @db.Decimal(10,3)  // what the scale actually said
  isOffal        Boolean  @default(false)    // copied from the template cut at record time, in case the template changes later
  productId      String?                    // which inventory Product this got stocked into, if any

  event   DismantleEvent @relation(fields: [eventId], references: [id])
  product Product?       @relation(fields: [productId], references: [id])
}
