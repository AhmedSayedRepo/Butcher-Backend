DATABASE_URL=postgresql://user:password@localhost:5432/butcher
JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated list of exact frontend origins allowed to send credentialed
# requests (cookies). Required in production — without it CORS falls back to
# reflecting the request's own Origin, which works for a single-tenant tool
# but should be pinned down once the real frontend domain is known.
CORS_ORIGIN=http://localhost:3000
ADMIN_EMAIL=admin@butcher.app
ADMIN_PASSWORD=admin123
PORT=8080
# Set to "production" on Railway/any real deployment — this flips the auth
# cookie to Secure + SameSite=None, which cross-site cookies require (see
# src/routes/auth.ts). Leave unset for local dev (SameSite=Lax, no HTTPS needed).
NODE_ENV=development
# Optional outgoing side-channel notifications (Phase F) — e.g. a Make.com
# webhook URL. Leave unset to disable; fireWebhook() no-ops without it.
WEBHOOK_URL=
# WhatsApp customer order intake (Phase I.2) — set these once you've created
# a Meta App with the WhatsApp product added (developers.facebook.com).
# WHATSAPP_VERIFY_TOKEN: any string you choose; enter the same value when
#   configuring the webhook subscription in Meta's dashboard.
# WHATSAPP_APP_SECRET: Meta App > Settings > Basic > App Secret. Required —
#   without it every inbound webhook call is rejected (signature check).
# WHATSAPP_ACCESS_TOKEN / WHATSAPP_PHONE_NUMBER_ID: needed only to send the
#   auto-reply confirmation; safe to leave unset while still testing draft
#   creation (Meta provides a temporary test number/token for development,
#   independent of your real business number's verification status).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional override; defaults to whatsapp-bot@system.internal (see
# prisma/seed.ts for why this seeded user exists).
WHATSAPP_SYSTEM_USER_EMAIL=
# v3.1 follow-up 5: admin-invite / password-reset auth flow, sent via plain
# Gmail SMTP (nodemailer) — switched from Resend because Resend refuses to
# deliver anywhere except the account owner's own inbox until a paid custom
# domain is verified, and the shop doesn't want that cost right now. Gmail
# SMTP is free and delivers to any recipient (~500/day cap, far more than a
# small shop's invite volume). Setup:
#   1. On the Google Account that should send these emails, turn on
#      2-Step Verification (myaccount.google.com/security).
#   2. Generate an App Password (myaccount.google.com/apppasswords) —
#      pick "Mail" / "Other", copy the 16-character password shown once.
#   3. SMTP_USER = that Gmail address. SMTP_APP_PASSWORD = the 16-char
#      password from step 2 (no spaces).
# Without both set (here OR from the app's own /settings page — see below),
# invite/reset emails simply don't send (no crash) — POST /api/users
# (invite) still works and returns the set-password link directly in the
# response so an admin can share it manually; POST /auth/forgot-password
# (self-service reset) has no such fallback and silently no-ops without
# email configured, since exposing that link in the API response would let
# anyone reset anyone's password.
# The display name on outgoing emails ("X <SMTP_USER>") is admin-editable
# from the app's Settings page (ShopSettings.mailSenderName) — not an env
# var — since Gmail requires the address itself to stay the authenticated
# account regardless.
#
# v3.1 follow-up 9 (ADR-016): SMTP_USER/SMTP_APP_PASSWORD can now ALSO be
# set from the app's own /settings page instead of only here — DB values
# (if present) win over these env vars, which remain the fallback for a
# deployment that hasn't configured /settings yet. The app password is
# stored encrypted (AES-256-GCM, see SETTINGS_ENCRYPTION_KEY below), never
# plaintext — but these env vars themselves are, same as every credential
# in this file, so still treat them with the same care.
SMTP_USER=
SMTP_APP_PASSWORD=
# v3.1 follow-up 9 (ADR-016): required only if you plan to set the Gmail
# app password from /settings rather than SMTP_APP_PASSWORD above — protects
# it at rest in Postgres. Any long random string (e.g. `openssl rand -hex 32`).
# Losing/rotating this makes any already-saved /settings app password
# permanently unreadable (falls back to SMTP_APP_PASSWORD above, or no email
# sending if that's unset too) — it does not affect anything else in the app.
SETTINGS_ENCRYPTION_KEY=
# Canonical frontend URL embedded in invite/reset email links (e.g. your
# Vercel URL). Falls back to the first entry in CORS_ORIGIN if unset.
FRONTEND_URL=
