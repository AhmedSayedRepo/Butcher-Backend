DATABASE_URL=postgresql://user:password@localhost:5432/butcher
JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated list of exact frontend origins allowed to send credentialed
# requests (cookies). Required in production — without it CORS falls back to
# reflecting the request's own Origin, which works for a single-tenant tool
# but should be pinned down once the real frontend domain is known.
CORS_ORIGIN=http://localhost:3000
ADMIN_EMAIL=admin@butcher.app
ADMIN_PASSWORD=admin123
PORT=8080
# Set to "production" on Railway/any real deployment — this flips the auth
# cookie to Secure + SameSite=None, which cross-site cookies require (see
# src/routes/auth.ts). Leave unset for local dev (SameSite=Lax, no HTTPS needed).
NODE_ENV=development
# Optional outgoing side-channel notifications (Phase F) — e.g. a Make.com
# webhook URL. Leave unset to disable; fireWebhook() no-ops without it.
WEBHOOK_URL=
# WhatsApp customer order intake (Phase I.2) — set these once you've created
# a Meta App with the WhatsApp product added (developers.facebook.com).
# WHATSAPP_VERIFY_TOKEN: any string you choose; enter the same value when
#   configuring the webhook subscription in Meta's dashboard.
# WHATSAPP_APP_SECRET: Meta App > Settings > Basic > App Secret. Required —
#   without it every inbound webhook call is rejected (signature check).
# WHATSAPP_ACCESS_TOKEN / WHATSAPP_PHONE_NUMBER_ID: needed only to send the
#   auto-reply confirmation; safe to leave unset while still testing draft
#   creation (Meta provides a temporary test number/token for development,
#   independent of your real business number's verification status).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional override; defaults to whatsapp-bot@system.internal (see
# prisma/seed.ts for why this seeded user exists).
WHATSAPP_SYSTEM_USER_EMAIL=
# ADR-017: admin-invite / password-reset auth flow, sent via Brevo's HTTP
# transactional email API. Went Resend -> Gmail SMTP -> Brevo: Resend
# refuses to deliver anywhere except the account owner's own inbox until a
# paid custom domain is verified; Gmail SMTP worked in principle but Render's
# free web services block ALL outbound traffic to SMTP ports (25/465/587) as
# an anti-spam measure (render.com/changelog/free-web-services-will-no-longer-allow-outbound-traffic-to-smtp-ports)
# — no application-level fix can work around that, since it's Render's own
# firewall, not this app's code. Brevo sends over plain HTTPS instead, which
# is never blocked. Setup:
#   1. Sign up at brevo.com (free tier: 300 emails/day, plenty for invites).
#   2. Add and verify a sender email under Senders, Domains & Dedicated IPs
#      — a single verified email works, no custom domain required.
#   3. Generate an API key under SMTP & API -> API Keys.
#   4. BREVO_SENDER_EMAIL = the verified sender address. BREVO_API_KEY = the
#      key from step 3.
# Without both set (here OR from the app's own /settings page — see below),
# invite/reset emails simply don't send (no crash) — POST /api/users
# (invite) still works and returns the set-password link directly in the
# response so an admin can share it manually; POST /auth/forgot-password
# (self-service reset) has no such fallback and silently no-ops without
# email configured, since exposing that link in the API response would let
# anyone reset anyone's password.
# The display name on outgoing emails ("X <BREVO_SENDER_EMAIL>") is
# admin-editable from the app's Settings page (ShopSettings.mailSenderName)
# — not an env var — since Brevo still requires the address itself to stay
# the verified sender regardless.
#
# BREVO_SENDER_EMAIL/BREVO_API_KEY can also be set from the app's own
# /settings page instead of only here — DB values (if present) win over
# these env vars, which remain the fallback for a deployment that hasn't
# configured /settings yet. The API key is stored encrypted (AES-256-GCM,
# see SETTINGS_ENCRYPTION_KEY below), never plaintext — but these env vars
# themselves are, same as every credential in this file, so still treat
# them with the same care.
BREVO_SENDER_EMAIL=
BREVO_API_KEY=
# Required only if you plan to set the Brevo API key from /settings rather
# than BREVO_API_KEY above — protects it at rest in Postgres. Any long
# random string (e.g. `openssl rand -hex 32`). Losing/rotating this makes
# any already-saved /settings API key permanently unreadable (falls back to
# BREVO_API_KEY above, or no email sending if that's unset too) — it does
# not affect anything else in the app.
SETTINGS_ENCRYPTION_KEY=
# Canonical frontend URL embedded in invite/reset email links (e.g. your
# Vercel URL). Falls back to the first entry in CORS_ORIGIN if unset.
FRONTEND_URL=
